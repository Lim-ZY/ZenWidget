<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Soft color bloom -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <gradient
                android:angle="315"
                android:centerColor="#33FFFFFF"
                android:endColor="#18B4C6FF"
                android:startColor="#28FFFFFF"
                android:type="linear" />
        </shape>
    </item>
    <!-- Frosted glass body -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <gradient
                android:angle="270"
                android:centerColor="#38FFFFFF"
                android:endColor="#1AFFFFFF"
                android:startColor="#52FFFFFF"
                android:type="linear" />
            <stroke
                android:width="1dp"
                android:color="#66FFFFFF" />
        </shape>
    </item>
    <!-- Top specular highlight -->
    <item
        android:bottom="28dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape android:shape="rectangle">
            <corners
                android:topLeftRadius="19dp"
                android:topRightRadius="19dp"
                android:bottomLeftRadius="12dp"
                android:bottomRightRadius="12dp" />
            <gradient
                android:angle="270"
                android:endColor="#00FFFFFF"
                android:startColor="#55FFFFFF"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
